---
import styles from './TopicCard.module.css';

interface Props {
  title: string;
  description: string;
  count: number;
  href: string;
}

const { title, description, count, href } = Astro.props;
---

<a href={href} class={styles.card}>
  <div class={styles.content}>
    <span class={styles.badge}>{count} {count === 1 ? 'material' : 'materiais'}</span>
    <h3 class={styles.title}>{title}</h3>
    <p class={styles.description}>{description}</p>
  </div>
  <div class={styles.action}>
    <span>Acessar acervo</span>
  </div>
</a>
